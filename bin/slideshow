#!/bin/bash
#
# slideshow — launches feh fullscreen inside the cage Wayland kiosk.
#
# Invoked by the systemd unit as:  cage -- /usr/local/bin/slideshow
# feh is an X11 app; cage provides Xwayland and sets DISPLAY for us.
#
# Slice 2 reads live off a USB stick mounted read-only at /media/frame by the
# frame-usb helper (udev). With no stick inserted that dir is missing/empty and
# we show the fallback image. Override PHOTO_DIR via /etc/slideshow.conf.

set -euo pipefail

# Config (overridable via the service's EnvironmentFile=/etc/slideshow.conf)
PHOTO_DIR="${PHOTO_DIR:-/media/frame}"
FALLBACK_IMAGE="${FALLBACK_IMAGE:-/usr/local/share/slideshow/black.jpg}"
SLIDE_SECONDS="${SLIDE_SECONDS:-30}"

# feh flags (per spec):
#   -f <file>     read the photo list from a file/fd (we build it, see below)
#   -D<n>         n seconds per photo
#   -z            random order
#   -Z            auto-zoom to fit
#   -F            fullscreen
#   --hide-pointer hide the mouse cursor
#   whole-image fit (no crop) → portraits get pillarboxed
#
# EXIF auto-rotation is handled transparently by Imlib2 (>=1.7.5) on Pi OS
# Bookworm, so feh's --auto-rotate is intentionally omitted (it's a no-op there
# and only emits a warning).
feh_opts=(
  -D"${SLIDE_SECONDS}"
  -z
  -Z
  -F
  --hide-pointer
)

# Build feh's photo list ourselves instead of using `feh -r`, so we can:
#   - exclude hidden dot-paths — Mac sticks carry .Spotlight-V100/.fseventsd
#     dirs full of non-image junk that feh -r would trawl and warn on;
#   - restrict to image types feh handles. HEIC/HEIF are included because
#     Mac-curated photos are commonly HEIC and feh decodes them natively here.
list_images() {
  find "$PHOTO_DIR" -type f -not -path '*/.*' \
    \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' \
       -o -iname '*.gif' -o -iname '*.bmp' -o -iname '*.webp' \
       -o -iname '*.heic' -o -iname '*.heif' \) 2>/dev/null
}

# If the dir holds at least one image, show them; otherwise fall back to a
# static image rather than letting feh exit immediately and crash-loop the
# service. (A proper "no photos" card arrives in a later slice.)
if [ -d "$PHOTO_DIR" ] && [ -n "$(list_images | head -n1)" ]; then
  exec feh "${feh_opts[@]}" -f <(list_images)
else
  echo "slideshow: no images in '$PHOTO_DIR', showing fallback image" >&2
  exec feh -F --hide-pointer "$FALLBACK_IMAGE"
fi
