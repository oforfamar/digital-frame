#!/bin/bash
#
# slideshow — launches feh fullscreen inside the cage Wayland kiosk.
#
# Invoked by the systemd unit as:  cage -- /usr/local/bin/slideshow
# feh is an X11 app; cage provides Xwayland and sets DISPLAY for us.
#
# Slice 2 reads live off a USB stick mounted read-only at /media/frame by the
# frame-usb helper (udev). With no stick inserted that dir is missing/empty and
# we show the fallback card. Override PHOTO_DIR via /etc/slideshow.conf.
#
# Slice 3 (readiness gate): there is always a usable display because cage starts
# us only once Xwayland is up. So we never show a black screen — until usable
# images appear at PHOTO_DIR we hold on the Romanian fallback card, then swap to
# the live slideshow the moment photos show up. This covers the cold-boot window
# before the stick is mounted, an empty/absent stick, and a pulled stick (the
# udev umount restarts us, so we land back on the card).

set -euo pipefail

SHARE_DIR="/usr/local/share/slideshow"

# Config (overridable via the service's EnvironmentFile=/etc/slideshow.conf)
PHOTO_DIR="${PHOTO_DIR:-/media/frame}"
# The Romanian no-photos card. If it is somehow missing, fall back to the plain
# black card rather than letting feh exit and leave the screen dark.
FALLBACK_IMAGE="${FALLBACK_IMAGE:-$SHARE_DIR/fallback.png}"
[ -f "$FALLBACK_IMAGE" ] || FALLBACK_IMAGE="$SHARE_DIR/black.jpg"
SLIDE_SECONDS="${SLIDE_SECONDS:-30}"
# How often the readiness gate re-checks PHOTO_DIR for usable images.
POLL_SECONDS="${POLL_SECONDS:-3}"

# feh flags (per spec):
#   -f <file>     read the photo list from a file/fd (we build it, see below)
#   -D<n>         n seconds per photo
#   -z            random order
#   -Z            auto-zoom to fit
#   -F            fullscreen
#   --hide-pointer hide the mouse cursor
#   whole-image fit (no crop) → portraits get pillarboxed
#
# EXIF auto-rotation is handled transparently by Imlib2 (>=1.7.5) on Pi OS
# Bookworm, so feh's --auto-rotate is intentionally omitted (it's a no-op there
# and only emits a warning).
feh_opts=(
  -D"${SLIDE_SECONDS}"
  -z
  -Z
  -F
  --hide-pointer
)

# Build feh's photo list ourselves instead of using `feh -r`, so we can:
#   - exclude hidden dot-paths — Mac sticks carry .Spotlight-V100/.fseventsd
#     dirs full of non-image junk that feh -r would trawl and warn on;
#   - restrict to image types feh handles. HEIC/HEIF are included because
#     Mac-curated photos are commonly HEIC and feh decodes them natively here.
list_images() {
  find "$PHOTO_DIR" -type f -not -path '*/.*' \
    \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' \
       -o -iname '*.gif' -o -iname '*.bmp' -o -iname '*.webp' \
       -o -iname '*.heic' -o -iname '*.heif' \) 2>/dev/null
}

has_images() { [ -d "$PHOTO_DIR" ] && [ -n "$(list_images | head -n1)" ]; }

# The fallback card runs as a background feh we own, so we can replace it with
# the slideshow the instant photos appear. Track its pid; (re)start it only when
# it isn't already up, so we don't flicker the card every poll.
fallback_pid=""
show_fallback() {
  if [ -n "$fallback_pid" ]; then
    kill -0 "$fallback_pid" 2>/dev/null && return  # card still up, no flicker
    wait "$fallback_pid" 2>/dev/null || true       # reap a card feh that exited
  fi
  echo "slideshow: no images in '$PHOTO_DIR' yet, showing fallback card" >&2
  feh -F --hide-pointer "$FALLBACK_IMAGE" &
  fallback_pid=$!
}
stop_fallback() {
  [ -n "$fallback_pid" ] || return 0
  kill "$fallback_pid" 2>/dev/null || true
  wait "$fallback_pid" 2>/dev/null || true
  fallback_pid=""
}
# A SIGTERM from `systemctl stop` (frame-usb bounces us on stick add/remove)
# must not orphan the background card.
trap 'stop_fallback; exit 0' TERM INT

# Readiness gate: hold on the fallback card until usable images appear, then
# swap to the live slideshow. `exec` hands our pid to feh so a crash propagates
# to cage/systemd and Restart=always brings the frame back.
while true; do
  if has_images; then
    stop_fallback
    exec feh "${feh_opts[@]}" -f <(list_images)
  fi
  show_fallback
  # Sleep in the background and `wait` on it so a SIGTERM from `systemctl stop`
  # runs the trap at once instead of being deferred until the sleep returns.
  sleep "$POLL_SECONDS" & wait $!
done
